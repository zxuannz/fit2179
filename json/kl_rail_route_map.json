{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "title": "Klang Valley Rail Network",
  "width": 380,
  "height": 380,
  "projection": {
    "type": "mercator",
    "center": [101.67, 3.10],
    "scale": 60000
  },
  "layer": [
    {
      "data": {
        "url": "https://raw.githubusercontent.com/zxuannz/fit2179/refs/heads/main/data/malaysia.topojson",
        "format": {"type": "topojson", "feature": "data"}
      },
      "mark": {
        "type": "geoshape",
        "fill": "#e8e8e8",
        "stroke": "#bbb",
        "strokeWidth": 0.5
      }
    },
    {
      "data": {
        "url": "https://raw.githubusercontent.com/zxuannz/fit2179/refs/heads/main/data/rail_shapes.csv"
      },
      "mark": {"type": "line", "strokeWidth": 4, "strokeCap": "round"},
      "encoding": {
        "longitude": {"field": "shape_pt_lon", "type": "quantitative"},
        "latitude": {"field": "shape_pt_lat", "type": "quantitative"},
        "order": {"field": "global_seq", "type": "quantitative"},
        "detail": {"field": "shape_id", "type": "nominal"},
        "color": {
          "field": "line",
          "type": "nominal",
          "scale": {
            "domain": ["LRT Ampang", "LRT Kelana Jaya", "LRT Sri Petaling", "KL Monorail", "MRT Kajang"],
            "range": ["#E57200", "#D50032", "#76232F", "#84BD00", "#047940"]
          },
          "legend": {"title": "Rail Line", "orient": "top-left"}
        }
      }
    },
    {
      "data": {
        "url": "https://raw.githubusercontent.com/zxuannz/fit2179/refs/heads/main/data/kl_rail_stations.csv"
      },
      "mark": {"type": "circle", "size": 40, "stroke": "#fff", "strokeWidth": 1.5},
      "encoding": {
        "longitude": {"field": "lon", "type": "quantitative"},
        "latitude": {"field": "lat", "type": "quantitative"},
        "color": {
          "field": "line",
          "type": "nominal",
          "scale": {
            "domain": ["LRT Ampang", "LRT Kelana Jaya", "KL Monorail", "MRT Kajang", "LRT Sri Petaling"],
            "range": ["#E57200", "#D50032", "#84BD00", "#047940", "#76232F"]
          },
          "legend": null
        },
        "tooltip": [
          {"field": "name", "title": "Station"},
          {"field": "line", "title": "Line"}
        ]
      }
    }
  ]
}